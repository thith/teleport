REPORT_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# Optional: skip auto-reminders during these hours (0–23, END exclusive, wraps midnight).
# Example for 22:00–07:59: START=22, END=8. Leave unset for 24/7 reminders.
# Uses the listener process's local timezone — set `TZ=Asia/Ho_Chi_Minh` in the same
# env if running under a service manager whose host TZ differs from yours.
QUIET_HOURS_START=
QUIET_HOURS_END=
